# Spotify API Variables
# Required for the "Now Playing" functionality.
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REFRESH_TOKEN=your_spotify_refresh_token_here

# GitHub Token
# Required for fetching GitHub contributions calendar.
GITHUB_TOKEN=your_github_personal_access_token_here

# Notion Integration
# Required for fetching CMS data (Projects, Writing, Reads, Experience).
NOTION_TOKEN=your_notion_integration_token_here

# Notion Database IDs
NOTION_PAGE_ID=your_notion_root_page_id
NOTION_PROJECTS_DB_ID=your_projects_database_id
NOTION_WRITING_DB_ID=your_writing_database_id
NOTION_READS_DB_ID=your_reads_database_id
NOTION_EXPERIENCE_DB_ID=your_experience_database_id
NOTION_SETTINGS_DB_ID=your_settings_database_id
